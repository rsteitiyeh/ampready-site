---
/**
 * Shared site footer for non-homepage pages (articles, /guides/).
 * Markup/classes mirror the homepage footer in Landing.astro so the
 * design stays consistent across the site.
 */
import site from '../../site.config.json';
---
<footer>
  <a class="brand" href="/">
    <svg width="20" height="20" viewBox="0 0 26 26" aria-hidden="true">
      <rect x="1.5" y="1.5" width="23" height="23" rx="5" style="fill:none;stroke:#FFD60A;stroke-width:1.6" />
      <polyline points="5,17 10,17 13,8 17,13 21,13" style="fill:none;stroke:#FFD60A;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round" />
    </svg>
    <span class="brand-word sm">Amp<b>Ready</b></span>
  </a>
  <nav><a href="/#practice-test">Practice Test</a><a href="/#study-guide">Study Guide</a><a href="/guides/">Guides</a><a href="/#faq">FAQ</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a><a href="/disclosure/">Disclosure</a><a href="/editorial/">Editorial</a></nav>
  <p>AmpExam is an independent study resource and is not affiliated with any state licensing board or the NFPA. NEC&reg; and National Electrical Code&reg; are registered trademarks of the National Fire Protection Association. <a href="/disclosure/">Read our full disclosure</a>.</p>
  <small>&copy; 2026 {site.BRAND}</small>
</footer>

<style>
  :root{--ink-dim:#8A919B;--yellow:#FFD60A;--ink-bright:#F2F3F5}
  a{color:var(--yellow);text-decoration:none}
  .brand-word{font-family:Oswald,"Arial Narrow",sans-serif;text-transform:uppercase}
  footer{max-width:1140px;margin:0 auto;padding:40px clamp(20px,5vw,48px) 48px}
  footer .brand{display:flex;align-items:center;gap:9px;color:var(--ink-bright);margin-bottom:26px}
  footer .brand-word.sm{font-size:16px;font-weight:700;letter-spacing:1.2px}
  footer .brand-word b{color:var(--yellow);font-weight:700}
  footer nav{display:flex;gap:clamp(14px,2.5vw,24px);flex-wrap:wrap;margin-bottom:26px}
  footer nav a{font-size:13.5px;color:var(--ink-dim)}
  footer p{font-size:13px;color:var(--ink-dim);line-height:1.7;margin:0 0 8px;max-width:780px}
  footer small{font-size:13px;color:var(--ink-dim)}
</style>
