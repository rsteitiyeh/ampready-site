---
import site from '../../site.config.json';
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
const t = site.theme;
---
<Base title={`Page not found | ${site.BRAND}`} noindex={true}>
  <SiteHeader />
  <main class="nf">
    <div>
      <p class="nf-code">404</p>
      <h1>Page not found</h1>
      <p>That link may be old, mistyped, or the page has moved. Here's how to get back on track.</p>
      <p>
        <a class="btn" href="/">Back to homepage</a>
        &nbsp;
        <a class="btn sm" href="/guides/">Browse all articles</a>
      </p>
    </div>
  </main>
  <SiteFooter />
</Base>

<style define:vars={{ bg: t.bg, ink: t.ink, accent: t.accent, headingFont: t.headingFont, bodyFont: t.bodyFont }}>
  .nf { min-height: 60vh; display: grid; place-items: center; text-align: center; background: var(--bg); color: var(--ink); font-family: var(--bodyFont); padding: 48px 24px; }
  .nf-code { font-size: 64px; font-weight: 900; color: var(--accent); margin: 0; }
  .nf h1 { font-family: var(--headingFont); }
</style>
