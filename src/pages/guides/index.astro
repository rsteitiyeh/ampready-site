---
import { getCollection } from 'astro:content';
import site from '../../../site.config.json';
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`Articles | ${site.BRAND}`} description={`All articles from ${site.BRAND}.`}>
  <SiteHeader />
  <div class="ad">Advertisement</div>
  <main class="guides">
    <h1>Articles</h1>
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/${a.id}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <small>{fmt(a.data.updatedDate ?? a.data.publishDate)}</small>
        </li>
      ))}
    </ul>
    {articles.length === 0 && <p>Articles are coming soon.</p>}
    <div class="ad">Advertisement</div>
  </main>
  <SiteFooter />
</Base>

<style define:vars={{ bg: site.theme.bg, ink: site.theme.ink, accent: site.theme.accent, headingFont: site.theme.headingFont, bodyFont: site.theme.bodyFont }} is:global>
  .ad{height:90px;width:min(970px,calc(100% - 32px));margin:27px auto;display:grid;place-items:center;border:1px dashed #2E333C;border-radius:8px;color:#6F7680;font:11px ui-monospace,Menlo,monospace;letter-spacing:1.8px;text-transform:uppercase}
  .guides { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; background: var(--bg); color: var(--ink); font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); }
  .guides h1 { font-family: var(--headingFont); }
  ul { list-style: none; padding: 0; }
  li { margin: 24px 0; }
  li a { font-weight: 700; font-size: 20px; color: var(--accent); font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); text-decoration: none; }
  li a:hover { text-decoration: underline; }
  li p { margin: 4px 0; font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); }
  small { opacity: .7; font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); }
  body { font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); }
  footer, footer * { font-family: var(--bodyFont, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif); }
</style>
